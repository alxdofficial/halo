# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/

# Heavy artifacts anywhere — never commit (regenerated from source)
*.npy
*.npz
*.parquet
*.pt
*.mdl
*.ckpt
*.pth
*.tar.gz

# data/: CODE and dataset metadata ARE tracked; downloads & generated grids are NOT.
data/datasets/*/downloads/
data/datasets/*/download/
data/datasets/*/raw/
data/datasets/*/sessions/
data/datasets/*/processed/
data/**/bundles/
training_output/
test_output/

# baselines/: adapters + citations ARE tracked; cloned upstream repos are NOT.
baselines/*/repo/
auxiliary_repos/

# Secrets — never commit
.env
*.env
cloud/.env
*.key
*.pem
credentials*.json

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
