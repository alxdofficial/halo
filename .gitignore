# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/

# Heavy artifacts anywhere — never commit (regenerated from source)
*.npy
*.npz
*.parquet
*.pt
*.mdl
*.ckpt
*.pth
*.tar.gz

# data/: CODE and authored metadata ARE tracked; downloads & converter-generated files are NOT.
# Authored (tracked): convert.py, metadata.json, eval_labels.json.
# Generated (ignored): sessions/, grids/, manifest.json, labels.json (session->activity map).
data/datasets/*/downloads/
data/datasets/*/download/
data/datasets/*/raw/
data/datasets/*/sessions/
data/datasets/*/processed/
data/datasets/*/grids/
data/datasets/*/manifest.json
data/datasets/*/labels.json
data/datasets/*/debug_*.png
data/**/bundles/
training_output/
test_output/
eval/results/

# baselines/: adapters + citations ARE tracked; cloned upstream repos are NOT.
baselines/*/repo/
auxiliary_repos/

# Secrets — never commit
.env
*.env
cloud/.env
*.key
*.pem
credentials*.json

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
training/tokenizer/outputs/**/*.pt

# Per-run training/eval artifacts (logs, eval jsons); .pt already ignored above.
# Keep one-time analysis deliverables (m0_probe/, m2_gate/, corpus_audit/, objective_health/).
training/tokenizer/outputs/pretrain*/
training/tokenizer/outputs/**/*.log
